# Klleon Avatar SDK
NEXT_PUBLIC_KLLEON_SDK_KEY=your-klleon-sdk-key
NEXT_PUBLIC_KLLEON_AVATAR_ID=your-klleon-avatar-id

# OpenAI (NLP - order parsing via GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcdonalds?connection_limit=10

# DynamoDB (optional - app works without these for local dev)
# DYNAMODB_TABLE_SESSIONS=kiosk-sessions
# DYNAMODB_TABLE_CACHE=menu-cache
# AWS_REGION=ap-southeast-1

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
