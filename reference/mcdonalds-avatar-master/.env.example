# Klleon Avatar SDK (handles STT + TTS + Avatar)
NEXT_PUBLIC_KLLEON_SDK_KEY=your_klleon_sdk_key_here
NEXT_PUBLIC_KLLEON_AVATAR_ID=your_avatar_id_here

# Google Gemini API (NLP - order parsing and response generation)
GOOGLE_API_KEY=your_google_api_key_here
NEXT_PUBLIC_LLM_PROVIDER=gemini-flash

# Supabase (Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (Payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
